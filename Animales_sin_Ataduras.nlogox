<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[;; ------------------------------------------------------------------------------------------------------------------------
;; DEFINE VARIABLES
;; ------------------------------------------------------------------------------------------------------------------------

patches-own [
  habitat
  buyable?
  parcel-id
  parcel-color
  parcel-price
  region-id
  network-region-id 
  protected-raster
]

breed [ tapirs tapir ]
breed [ place-labels place-label ]

globals [
  bank-balance
  show-price? 
  temp-score
  temp-range-score  
  temp-network-score
  mouse-was-down? 
  purchase-id
  median-parcel-price
  region-size
  
  temp-score-history
  temp-range-score-history
  temp-network-score-history
  completion-tick
  region-centroids
  window-size
  repeat-temp-score
  repeat-temp-range-score
  repeat-temp-network-score
  score
  range-score
  network-score
  r_world
]

tapirs-own [
  visited-regions      ;; rolling list of patches
  region-coverage             ;; fraction of landscape used
  last-region
  transition-list
  network-nodes
  network-edges
  network-weighted
  overall-temp-score
  overall-temp-range-score
  overall-temp-network-score
    visited-patches   ;; list of patches this tapir has visited
  area-covered      ;; number of unique habitat patches visited

]


;; ------------------------------------------------------------------------------------------------------------------------
;; SETUP THE LANDSCAPE
;; ------------------------------------------------------------------------------------------------------------------------


;; ---------------------------------------------------------------
;; MAIN LANDSCAPE CODE
;; ---------------------------------------------------------------


