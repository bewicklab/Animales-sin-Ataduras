  apply-internal-raster
  
  ;;LABEL THE NATIONAL PARKS
  setup-place-labels
  
  ;;INITIALIZE PATCH VARIABLES
  ask patches [
  set buyable? (habitat = 0)
  set parcel-id 0
  ]
  
  ;;HABITAT IS ANYTHING IN A PROTECTED AREA
  ask patches [
    if habitat > 0 [ set habitat  1 ]
    if habitat = 1 [set pcolor green ]
    if habitat = 0 [ set pcolor black ]
  ]

  ;;DIVIDE THE REGION INTO SQUARES (USED TO FIGURE OUT COARSE GRAINED VISITATION)
  assign-regions
  ;;DIVIDE REGION INTO PARKS
  assign-network-regions
  
  ;;CREATE PARCELS (NUMBER SPECIFIED IN INTERFACE) THAT ARE AT LEAST 50 PATCHES
  let min-parcel-size 50
  assign-parcel-seeds parcelas-iniciales
  fill-parcels-deterministic
  enforce-min-parcel-size 50
  
  
  ;;ASSIGN PRICES TO PARCELS AND COLOR ACCORDING TO PRICE
  assign-parcel-prices
  set median-parcel-price median [parcel-price] of patches with [habitat = 0]
  color-parcels-by-price
  
  ;;INITIALIZE temp-score VARIABLES
  set temp-score-history []
  set temp-score 0

  reset-ticks
  
end


;; ------------------------------------------------------------------------------------------------------------------------
;; LANDSCAPE FUNCTIONS
;; ------------------------------------------------------------------------------------------------------------------------


to apply-internal-raster

  let rows length r_world
  let cols length first r_world

  ask patches [

    ;; scale patch → raster space
    let col floor ((pxcor - min-pxcor) / (max-pxcor - min-pxcor + 1) * cols)
    let row floor ((max-pycor - pycor) / (max-pycor - min-pycor + 1) * rows)

    ;; clamp to prevent overflow
    if col < 0 [ set col 0 ]
    if row < 0 [ set row 0 ]
    if col >= cols [ set col cols - 1 ]
    if row >= rows [ set row rows - 1 ]

    let val item col (item row r_world)

    set protected-raster val
    set habitat ifelse-value (val > 0) [1] [0]

  ]

end



;; ---------------------------------------------------------------
;; LABEL NATIONAL PARKS
;; ---------------------------------------------------------------

to setup-place-labels
  create-place-labels 1 [
    setxy 840 500
    set label "Sumaco-Napo Galeras"
    set label-color yellow
    set size 0
  ]

  create-place-labels 1 [
    setxy 575 800
    set label "Cayambe-Coca"
    set label-color yellow
    set size 0
  ]
  
  create-place-labels 1 [
    setxy 300 300
    set label "Antisano"
    set label-color yellow
    set size 0
  ]
end

;; ---------------------------------------------------------------
;; DIVIDE REGION INTO SQUARES (COARSE GRAINED VISITATION)
;; ---------------------------------------------------------------

to assign-regions
  let ncols ceiling ((max-pxcor - min-pxcor + 1) / region-size)

  ask patches [
    let rx floor ((pxcor - min-pxcor) / region-size)
    let ry floor ((pycor - min-pycor) / region-size)
    set region-id ry * ncols + rx
  ]
end

;; ---------------------------------------------------------------
;; DIVIDE REGION INTO PARKS
;; ---------------------------------------------------------------

to assign-network-regions
  ask patches [
    if protected-raster > 0 [
      set network-region-id protected-raster
    ]
    if protected-raster = 0 [
      set network-region-id 0
    ]
  ]
end

;; ---------------------------------------------------------------
;; CREATE PARCELS
;; ---------------------------------------------------------------

to assign-parcel-seeds [n]
  let seeds n-of n patches with [buyable?]

  let pid 1
  foreach sort seeds [
    p ->
    ask p [ set parcel-id pid ]
    set pid pid + 1
  ]
end

to fill-parcels-deterministic
  let seeded patches with [parcel-id > 0]

  ask patches with [habitat = 0 and parcel-id = 0] [
    let nearest min-one-of seeded [distance myself]
    set parcel-id [parcel-id] of nearest
  ]
end

to enforce-min-parcel-size [min-size]

  let parcel-ids remove-duplicates
    [parcel-id] of patches with [habitat = 0]

  foreach parcel-ids [
    pid ->
    let ps patches with [parcel-id = pid]

    if count ps < min-size [
      ;; find neighboring parcels
      let neighbor-patches patches with [
        habitat = 0 and
        parcel-id != pid and
        any? neighbors4 with [parcel-id = pid]
      ]

      if any? neighbor-patches [
        let target one-of neighbor-patches
        let target-id [parcel-id] of target

        ask ps [
          set parcel-id target-id
        ]
      ]
    ]
  ]
end

;; ---------------------------------------------------------------
;; ASSIGN PARCEL PRICES AND COLOR ACCORDINGLY
;; ---------------------------------------------------------------

to assign-parcel-prices
  let parcel-ids remove-duplicates
    [parcel-id] of patches with [parcel-id > 0]

  foreach parcel-ids [
    pid ->
    let ps patches with [parcel-id = pid]

    ;; deterministic component
    let parcel-area count ps
    let base-price 10000 + parcel-area * 10

    ;; randomness: ±20%
    let noise-factor 1 + random-normal 0 0.2

    ;; prevent negative or extreme values
    let price max list 100 (base-price * noise-factor)

    let rounded round (price / 1000) * 1000
    
    ask ps [
      set parcel-price rounded
    ]
  ]
end

to color-parcels-by-price
  let min-price min [parcel-price] of patches with [parcel-id > 0] 
  let max-price max [parcel-price] of patches with [parcel-id > 0] 

  
  let med median-parcel-price 
  ask patches with [parcel-id > 0] [
    
    ifelse parcel-price > med [
    set pcolor scale-color red parcel-price max-price med
    ]
    [
      set pcolor scale-color blue parcel-price min-price med
    ]
  ]

  ask patches with [habitat = 1] [
    set pcolor green
  ]
end


;; ------------------------------------------------------------------------------------------------------------------------
;; PLAY THE GAME
;; ------------------------------------------------------------------------------------------------------------------------

;; ---------------------------------------------------------------
;; PURCHASE PARCELS
;; ---------------------------------------------------------------


to click-patch
  if mouse-down? and not mouse-was-down? [
    set mouse-was-down? true

    let p patch mouse-xcor mouse-ycor
    if p != nobody [

      let pid [parcel-id] of p
      if pid > 0 [

        ;; store original colors for the whole parcel
        let old-colors [pcolor] of patches with [parcel-id = pid]

        ;; temporarily highlight parcel
        ask patches with [parcel-id = pid] [
          set pcolor yellow
        ]

        let price one-of [parcel-price] of patches with [parcel-id = pid]

        ifelse bank-balance >= price [
          let buy? user-yes-or-no?
  (word "Esta parcela cuesta $"
        round (price / 1000) "K.\n\nSelecciona:\nYes = Comprar\nNo = Cancelar\nHalt = Salir")
          if buy? [
            ;; BUY: permanent change
            set bank-balance bank-balance - price
            ask patches with [parcel-id = pid] [
              set habitat 1
              set parcel-id 0
              set pcolor green
            ]
          ]

          if not buy? [
            ;; NOT BUY: restore original colors
            let i 0
            ask patches with [parcel-id = pid] [
              set pcolor item i old-colors
              set i i + 1
            ]
          ]
        ]

         [
          user-message (word "Esta parcela cuesta $"
                  round (price / 1000) "K. No tienes suficiente dinero para comprar esta parcela. \n\nPresiona OK para continuar.\nPresiona Halt para salir.")

          ;; restore original colors
          let i 0
          ask patches with [parcel-id = pid] [
            set pcolor item i old-colors
            set i i + 1
          ]
        ]
      ]
    ]
  ]

  if not mouse-down? [
    set mouse-was-down? false
  ]
end


;; ---------------------------------------------------------------
;; FUNDRAISE
;; ---------------------------------------------------------------

to go
  ;; 1. Increment bank balance
  set bank-balance bank-balance + recaudacion-anual

  ;; 2. Choose how many parcels to convert this tick (0–4)
  let n random 10

  ;; 3. List of eligible parcel IDs
  let available-parcels remove-duplicates
    [parcel-id] of patches with [habitat = 0 and parcel-id > 0]

  ;; 4. Convert up to n parcels
  if not empty? available-parcels [
    let chosen n-of (min list n length available-parcels) available-parcels

    foreach chosen [
      pid ->
      ask patches with [parcel-id = pid] [
        set habitat 2
        set parcel-id 0
        set pcolor brown
      ]
    ]
  ]
 
  if completion-tick = nobody and
   count patches with [ habitat = 0 ] = 0 [
  set completion-tick ticks
]

  
end


;; ------------------------------------------------------------------------------------------------------------------------
;; temp-score THE RESULTS
;; ------------------------------------------------------------------------------------------------------------------------

to test-model
  set repeat-temp-score 0
  set temp-score 0
  set score 0
  set repeat-temp-range-score 0
  set temp-range-score 0
  set range-score 0
  set repeat-temp-network-score 0
  set temp-network-score 0
  set network-score 0
  repeat 20 [
  test-model-trial
]
  
  set score repeat-temp-score / 20
  set range-score repeat-temp-range-score / 20
  set network-score repeat-temp-network-score / 20
end

to test-model-trial
  set temp-score 0
  setup-tapirs
  ask tapirs [
  set last-region 0
  set region-coverage 0
  set network-edges 0
  set network-nodes 0
  set network-weighted 0
  set overall-temp-score 0
  set overall-temp-range-score 0
  set overall-temp-network-score 0
  set area-covered 0
]
  reset-ticks
  while [ticks < 100] [
  move-tapirs
  ]
  
  set repeat-temp-score repeat-temp-score + temp-score
  set repeat-temp-range-score repeat-temp-range-score + temp-range-score
  set repeat-temp-network-score repeat-temp-network-score + temp-network-score
end

;; ------------------------------------------------------------------------------------------------------------------------
;; TAPIR FUNCTIONS
;; ------------------------------------------------------------------------------------------------------------------------


;; ---------------------------------------------------------------
;; SETUP AND INITIALIZE TAPIRS
;; ---------------------------------------------------------------

to setup-tapirs

  compute-region-centroids  
  create-tapirs-at-centroids
  
  set temp-score 0
  set temp-score-history []
  set temp-range-score 0
  set temp-range-score-history []
  set temp-network-score 0
  set temp-network-score-history []

  
  ask tapirs [
  set visited-regions []        ;; start empty (window logic)
  set region-coverage 0

  set last-region [network-region-id] of patch-here
    
  set transition-list []

  set network-nodes 0
  set network-edges 0
  set network-weighted 0
  set overall-temp-score 0
  set overall-temp-range-score 0
  set overall-temp-network-score 0
]
    ask tapirs [
  set visited-patches []
  set area-covered 0
]

end


to compute-region-centroids
  set region-centroids []

  let region-list remove-duplicates [ network-region-id ] of patches with [ network-region-id > 0 ]

  let r-index 0
  while [r-index < length region-list] [
    let r (item r-index region-list)

    let ps patches with [ network-region-id = r ]

    let cx mean [ pxcor ] of ps
    let cy mean [ pycor ] of ps

    set region-centroids
      lput (list r cx cy) region-centroids

    set r-index r-index + 1
  ]
end


to create-tapirs-at-centroids
  clear-turtles

  let i 0
  while [i < length region-centroids] [
    let c (item i region-centroids)

    create-tapirs 5 [
      setxy (item 1 c) (item 2 c)
      rt random 360
          set color black
    set size 30
    set shape "sheep"   ;; or "cow", "sheep", etc.

    ]
    create-tapirs 295 [
      setxy (item 1 c) (item 2 c)
      rt random 360
          set color black
    set size 0
    set shape "sheep"   ;; or "cow", "sheep", etc.

    ]

    set i i + 1
  ]
end


;; ---------------------------------------------------------------
;; MOVE TAPIRS
;; ---------------------------------------------------------------

to move-tapirs
  
  
  ask tapirs [
    
    let tries 0
    
    while [tries < 20] [
      
      boundary-turn-bias
      if corridor-ahead? 5 [
        rt random-float 1 - random-float 1
      ]
      
      let next-patch patch-ahead 1
      
      ifelse next-patch != nobody and [habitat] of next-patch = 1 [
        fd 1
        set tries tries + 1
      ]
      [set tries tries + 1
        rt random 50 - random 50
      ]
    ]
    
  ]
  
  make-transition-list
  make-region-list
  
  find-overall-temp-score
  
  let raw-temp-score mean [overall-temp-score] of tapirs 
  let raw-temp-range-score mean [overall-temp-range-score] of tapirs 
  let raw-temp-network-score mean [overall-temp-network-score] of tapirs 
  
  update-temp-score raw-temp-score raw-temp-range-score raw-temp-network-score

     tick
end

to-report corridor-ahead? [d]
  let i 1
  while [i <= d] [
    let p patch-ahead i
    if p = nobody [ report false ]
    if [habitat] of p = 1 [ report true ]
    set i i + 1
  ]
  report false
end

to boundary-turn-bias
  let edge? any? neighbors4 with [habitat = 0]

  if edge? [
    ;; small bias, not deterministic
    rt random-float 0 - random-float 0
  ]
end


;; ---------------------------------------------------------------
;; TRACK MOVEMENT METRICS
;; ---------------------------------------------------------------


 to make-transition-list
  ask tapirs [
    let current-region [network-region-id] of patch-here
    
    ;; only consider parks (1, 2, 3)
    if current-region > 0 and last-region > 0 and current-region != last-region [
      set transition-list
      lput (list last-region current-region) transition-list
    ]
    
    ;; update last-region only when in a park
    if current-region > 0 [
      set last-region current-region
    ]
    
    if length transition-list > window-size [
      set transition-list but-first transition-list
    ]
  ]
end

to make-region-list
  ask tapirs [
    let r [region-id] of patch-here
    set visited-regions lput r visited-regions
    
    if length visited-regions > window-size [
      set visited-regions but-first visited-regions
    ]
  ]
end



;; ---------------------------------------------------------------
;; temp-score HABITAT
;; ---------------------------------------------------------------

to find-overall-temp-score

  ask tapirs [
    let used-regions remove-duplicates visited-regions
    set region-coverage length used-regions
  ]


  ;; --------------------
  ;; NETWORK EDGES & NODES (park-only)
  ;; --------------------
  ask tapirs [

    ;; build clean edge list (no zeros)
    let edges []
    let k 0
    while [k < length transition-list] [
      if not member? 0 (item k transition-list) [
        set edges lput (item k transition-list) edges
      ]
      set k k + 1
    ]
    set edges remove-duplicates edges

    ;; build node list from edges
    let nodes []
    let m 0
    while [m < length edges] [
      let edge (item m edges)
      set nodes lput (item 0 edge) nodes
      set nodes lput (item 1 edge) nodes
      set m m + 1
    ]

    set nodes remove-duplicates nodes
    set network-edges length edges
    set network-nodes length nodes
  ]


  ;; --------------------
  ;; WEIGHTED NETWORK EDGES
  ;; --------------------
  ask tapirs [

    let unique-edges []
    let n 0
    while [n < length transition-list] [
      if not member? 0 (item n transition-list) [
        set unique-edges lput (item n transition-list) unique-edges
      ]
      set n n + 1
    ]
    set unique-edges remove-duplicates unique-edges

    let total 0
    let p 0
    while [p < length unique-edges] [
      let edge (item p unique-edges)
      let c 0

      let q 0
      while [q < length transition-list] [
        if (item q transition-list) = edge [
          set c c + 1
        ]
        set q q + 1
      ]

      set total total + c
      set p p + 1
    ]

    set network-weighted total
  ]


  ;; --------------------
  ;; FINAL NETWORK temp-score
  ;; --------------------
  ask tapirs [
    set overall-temp-range-score 4  * (region-coverage - 14.272)
    set overall-temp-network-score 8 * (network-weighted - 0.0772)
    set overall-temp-score 
      (4  * (region-coverage - 14.272)) +
      (8 * (network-weighted - 0.0772)) +
      (0. * network-edges)
  ]

end






to update-temp-score [ new-temp-score new-temp-range-score new-temp-network-score ]
  ;; add newest temp-score to the front  
  set temp-score-history fput new-temp-score temp-score-history  
  set temp-range-score-history fput new-temp-range-score temp-range-score-history  
  set temp-network-score-history fput new-temp-network-score temp-network-score-history  
  ;; keep only last 100
  
  
  
  
  
;    if length temp-score-history > 100 [
;    set temp-score-history sublist temp-score-history
;                                   (length temp-score-history - 100)
;                                   length temp-score-history

;    set temp-range-score-history sublist temp-range-score-history
;                                         (length temp-range-score-history - 100)
;                                         length temp-range-score-history

;    set temp-network-score-history sublist temp-network-score-history
;                                           (length temp-network-score-history - 100)
;                                           length temp-network-score-history
;    ]
  
 
   ;;rolling average
  ;;if temp-score > mean temp-score-history  [
    set temp-score mean temp-score-history
    set temp-range-score mean temp-range-score-history
    set temp-network-score mean temp-network-score-history
  ;;]
  
end

]]></code>
